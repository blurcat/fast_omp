# ============================================================
# Ops Middle Platform 环境变量配置模板
# 复制此文件为 .env 并填写真实值后使用
# 注意：.env 文件不应提交到代码仓库
# ============================================================

# ---- 安全配置（必填） ----
# 用 `openssl rand -hex 32` 生成强随机密钥
SECRET_KEY=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET

# ---- 数据库配置 ----
POSTGRES_USER=fast_mm
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=fast_mm
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432

# ---- Redis 配置 ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- CORS 配置 ----
# 生产环境请配置具体域名，多个域名用逗号分隔
# 示例: ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- 初始化超级管理员（首次部署使用） ----
FIRST_SUPERUSER=admin
FIRST_SUPERUSER_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
FIRST_SUPERUSER_EMAIL=admin@example.com

# ---- 开发环境专用 ----
# 设置为 true 可在开发时跳过 SECRET_KEY 安全校验（生产环境禁止）
# ALLOW_INSECURE_SECRET_KEY=true
